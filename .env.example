# ─────────────────────────────────────────────
#  moqompare — environment variables
#  Copy to .env and adjust before running.
# ─────────────────────────────────────────────

# ── Logging ──────────────────────────────────
LOG_LEVEL=info
# How often idle placeholder services log a heartbeat (seconds)
LOG_INTERVAL=30

# ── Live source ───────────────────────────────
# Path to a directory containing *.mp4 video files to loop as the live source.
# Falls back to synthetic testsrc2 if the directory is empty or missing.
VIDEOS_DIR=./videos
SOURCE_FPS=30
SOURCE_RESOLUTION=1920x1080
SOURCE_BITRATE=4000k

# ── Packager ─────────────────────────────────
# Duration of each HLS segment / media fragment in seconds
HLS_SEGMENT_DURATION=2
# Number of segments to keep in the rolling HLS manifest
HLS_LIST_SIZE=5

# ── Network ports (host-side) ─────────────────
# HLS HTTP origin
ORIGIN_PORT=8080
# MoQ relay (QUIC/WebTransport)
RELAY_PORT=4443
# Browser comparison UI
WEB_PORT=3000
# Metrics / Prometheus scrape endpoint
METRICS_PORT=9090

# ── MoQ relay (internal) ─────────────────────
# Hostname used by publisher to reach the relay inside the compose network
RELAY_HOST=relay

# ── Impairment (Phase 3+) ─────────────────────
# Interface impairments are applied to (set to the compose network interface)
IMPAIR_IFACE=eth0
